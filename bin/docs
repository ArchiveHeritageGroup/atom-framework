#!/usr/bin/env bash
# ============================================================
# Heratio Documentation Generator
# Usage: ./bin/docs [--no-cache]
# ============================================================
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FRAMEWORK_PATH="$(dirname "$SCRIPT_DIR")"
PHPDOC="/usr/local/bin/phpdoc"
CONFIG="${FRAMEWORK_PATH}/phpdoc.xml"
DOCS_PATH="${FRAMEWORK_PATH}/docs/api"
CACHE_PATH="${FRAMEWORK_PATH}/docs/.phpdoc/cache"
LOG_FILE="/tmp/phpdoc-$(date +%Y%m%d-%H%M%S).log"

# Colours
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

echo -e "${GREEN}========================================${NC}"
echo -e "${GREEN}  Heratio Documentation Generator${NC}"
echo -e "${GREEN}========================================${NC}"

cd "$FRAMEWORK_PATH"

# Optional: clear cache
if [[ "$1" == "--no-cache" ]]; then
    echo -e "${YELLOW}Clearing documentation cache...${NC}"
    rm -rf "$CACHE_PATH"
    mkdir -p "$CACHE_PATH"
fi

# Ensure output directory exists
mkdir -p "$DOCS_PATH"

echo -e "${YELLOW}Generating API documentation...${NC}"
echo "Log: $LOG_FILE"
echo ""

# Run phpDocumentor
"$PHPDOC" run --config "$CONFIG" 2>&1 | tee "$LOG_FILE"

# Check result
if [ $? -eq 0 ]; then
    DOC_COUNT=$(find "$DOCS_PATH" -name "*.html" | wc -l)
    echo ""
    echo -e "${GREEN}Documentation generated successfully${NC}"
    echo -e "${GREEN}${DOC_COUNT} HTML pages created${NC}"
    echo -e "${GREEN}Available at: https://psis.theahg.co.za/docs/${NC}"
else
    echo ""
    echo -e "${RED}Documentation generation failed${NC}"
    echo -e "${RED}Check log: $LOG_FILE${NC}"
    exit 1
fi
